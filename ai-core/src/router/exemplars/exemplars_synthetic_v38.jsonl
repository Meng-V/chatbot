{"intent": "location_directions", "utterance": "where is the Middletown library located", "source": "synthetic_v38"}
{"intent": "location_directions", "utterance": "What building is the art library in?", "source": "synthetic_v38"}
{"intent": "location_directions", "utterance": "Where is SWORD?", "source": "synthetic_v38"}
{"intent": "location_directions", "utterance": "How do I get to the regional depository?", "source": "synthetic_v38"}
