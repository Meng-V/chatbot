// Colleague Round 1 test (Nov 20, 2025) — questions used by Miami librarian
// colleague to test v1 of the chatbot, which produced many wrong/hallucinated
// answers and blocked deployment. Re-running on v2 to demonstrate improvement.
//
// Source: /Users/qum/Desktop/Test Questions for Chatbot - Answer Log.docx
// IDs prefixed `r1_` so no collisions with the main 234-case golden_set.jsonl.
// Expected answers reflect what v2 SHOULD do per the design contract
// (the colleague's recorded answers were the v1 bot's output, mostly wrong).

{"id":"r1_hours_general","question":"What are the library hours?","intent":"hours","scope_campus":"oxford","scope_library":"king","expected_answer":"Should call get_hours for King (the default flagship) and return today's open/close window from live LibCal, citing the King hours page or campus hours hub. Should NOT invent 7am-1am for every day of the week (v1 bot hallucinated this).","expected_outcome":"answer","allowed_urls":["https://www.lib.miamioh.edu/about/locations/king-library/","https://www.lib.miamioh.edu/about/locations/hours/"],"category":"r1_hours","notes":"v1: hallucinated identical hours every day"}
{"id":"r1_hours_thanksgiving","question":"Are you open on Thanksgiving?","intent":"hours","scope_campus":"oxford","scope_library":null,"expected_answer":"Should state Thanksgiving Day closure (university is closed) and cite the hours hub for the full holiday schedule. Should not refuse with a 'URL removed' message (v1 did this).","expected_outcome":"answer","allowed_urls":["https://www.lib.miamioh.edu/about/locations/hours/"],"category":"r1_hours","notes":"v1: stripped URL incorrectly"}
{"id":"r1_hours_wertz","question":"What are the hours for the Art and Architecture Library?","intent":"hours","scope_campus":"oxford","scope_library":"wertz","expected_answer":"Should call get_hours for Wertz (resolve 'Art and Architecture' → wertz via alias table) and return today's window from live LibCal, citing the Wertz location page or hours hub. v1 refused; v2 should succeed.","expected_outcome":"answer","allowed_urls":["https://www.lib.miamioh.edu/about/locations/art-arch/","https://www.lib.miamioh.edu/about/locations/hours/"],"category":"r1_hours","notes":"v1: refused"}
{"id":"r1_hours_wertz_named","question":"What are the hours for the Wertz Art Library?","intent":"hours","scope_campus":"oxford","scope_library":"wertz","expected_answer":"Same as r1_hours_wertz — should resolve 'Wertz' alias and return live hours from get_hours, citing the Wertz location page.","expected_outcome":"answer","allowed_urls":["https://www.lib.miamioh.edu/about/locations/art-arch/","https://www.lib.miamioh.edu/about/locations/hours/"],"category":"r1_hours","notes":"v1: refused even with full Wertz name"}
{"id":"r1_hours_makerspace","question":"What are the hours for the Makerspace?","intent":"makerspace_3d","scope_campus":"oxford","scope_library":"king","expected_answer":"Should call get_hours for makerspace (or surface the MakerSpace LibGuide hours block) and cite the makerspace page. v1 refused.","expected_outcome":"answer","allowed_urls":["https://www.lib.miamioh.edu/use/spaces/makerspace/","https://libguides.lib.miamioh.edu/create/makerspace"],"category":"r1_hours","notes":"v1: refused"}
{"id":"r1_hours_special_collections","question":"What are the hours for Special Collections?","intent":"hours","scope_campus":"oxford","scope_library":"special","expected_answer":"Should call get_hours for Special Collections and report whatever the LibCal API returns (whether that's specific hours like '9am to 4pm' or 'appointment only' or 'closed today'). Trust the live API — do not second-guess it. Cite the Special Collections page. v1 crashed then refused.","expected_outcome":"answer","allowed_urls":["https://www.lib.miamioh.edu/about/locations/special-collections-archives/","https://spec.lib.miamioh.edu/"],"category":"r1_hours","notes":"v1: crashed the system, then refused. Updated 2026-05-27: gold relaxed to accept whatever LibCal returns for the SC location ID, per librarian guidance — don't second-guess the API."}
{"id":"r1_hours_hamilton","question":"What are the hours for Hamilton Library?","intent":"hours","scope_campus":"hamilton","scope_library":"rentschler","expected_answer":"Should call get_hours for Rentschler (Hamilton) and return today's window from live LibCal, citing the Hamilton library hours page. v1 refused.","expected_outcome":"answer","allowed_urls":["https://www.ham.miamioh.edu/library/about/hours/","https://www.lib.miamioh.edu/about/locations/hours/"],"category":"r1_hours","notes":"v1: refused"}
{"id":"r1_hours_middletown","question":"What are the hours for Middletown Library?","intent":"hours","scope_campus":"middletown","scope_library":"gardner_harvey","expected_answer":"Should call get_hours for Gardner-Harvey (Middletown) and return today's window from live LibCal. v1 refused.","expected_outcome":"answer","allowed_urls":["https://www.mid.miamioh.edu/library/","https://www.lib.miamioh.edu/about/locations/hours/"],"category":"r1_hours","notes":"v1: refused"}

