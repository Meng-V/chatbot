{"id":"r1_addr_hamilton","question":"What is the address of Hamilton Library?","intent":"location_directions","scope_campus":"hamilton","scope_library":"rentschler","expected_answer":"Should surface Rentschler Library's address from the Hamilton library page.","expected_outcome":"answer","allowed_urls":["https://www.ham.miamioh.edu/library/about/","https://www.lib.miamioh.edu/about/locations/regional/"],"category":"r1_address"}
